{
  "name": "homeinone-init",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
