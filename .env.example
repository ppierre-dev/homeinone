# Application
NODE_ENV="development"
APP_PORT=3000

# Database — PostgreSQL
DATABASE_URL="postgresql://homeinone:homeinone@db:5432/homeinone"
POSTGRES_USER="homeinone"
POSTGRES_PASSWORD="homeinone"
POSTGRES_DB="homeinone"
POSTGRES_PORT=5432

# Redis
REDIS_URL="redis://redis:6379"
REDIS_PORT=6379

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="change-me-in-production"

# Upload
UPLOAD_DIR=/uploads
UPLOAD_MAX_SIZE_MB=10
